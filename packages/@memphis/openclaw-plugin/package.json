{
  "name": "@memphis/openclaw-plugin",
  "version": "0.1.0",
  "description": "Memphis Memory Provider for OpenClaw - Persistent memory layer with cognitive models",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('node:fs'); fs.copyFileSync('openclaw.plugin.json','dist/openclaw.plugin.json');\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "memory",
    "memphis",
    "cognitive",
    "provider"
  ],
  "author": "Memphis-Chains",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Memphis-Chains/memphis-v5.git",
    "directory": "packages/@memphis/openclaw-plugin"
  },
  "bugs": {
    "url": "https://github.com/Memphis-Chains/memphis-v5/issues"
  },
  "homepage": "https://github.com/Memphis-Chains/memphis-v5#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "provides": [
      "memory"
    ],
    "name": "Memphis Memory Provider",
    "icon": "△⬡◈"
  }
}
