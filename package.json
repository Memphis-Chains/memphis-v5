{
  "name": "@memphis-chains/memphis-v4",
  "version": "0.1.3",
  "description": "Production-first Memphis v4 runtime (TS shell + Rust core bridge)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "memphis-v4": "bin/memphis-v4.js"
  },
  "files": [
    "dist",
    "bin",
    "scripts/install.sh",
    "README.md",
    "LICENSE",
    "docs/USER-QUICKSTART-GITHUB.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "test": "./scripts/test.sh",
    "test:ts": "vitest run",
    "test:rust": "bash -lc 'command -v cargo >/dev/null 2>&1 || source $HOME/.cargo/env; cargo test --workspace'",
    "test:smoke": "./scripts/smoke-test.sh",
    "build:rust": "bash -lc 'command -v cargo >/dev/null 2>&1 || source $HOME/.cargo/env; cargo build --workspace'",
