    "pack:dry-run": "npm pack --dry-run",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cli": "tsx src/infra/cli/index.ts",
    "bench:run": "tsx benchmarks/run.ts",
    "bench:run:update-baseline": "tsx benchmarks/run.ts --update-baseline",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "docs:typedoc": "typedoc --options typedoc.json",
    "release:smoke": "./scripts/release-smoke.sh",
    "ops:quality-runtime-pack": "./scripts/local-quality-runtime-pack.sh",
