NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
LOG_FORMAT=text

# Runtime API protection (required in production)
MEMPHIS_API_TOKEN=

# Optional. If omitted, Memphis defaults to Ollama-first setup and gracefully falls back to local-fallback.
# Supported values: ollama | local-fallback | shared-llm | decentralized-llm
DEFAULT_PROVIDER=ollama

# Configure only if you explicitly want hosted/shared providers.
SHARED_LLM_API_BASE=
SHARED_LLM_API_KEY=
DECENTRALIZED_LLM_API_BASE=
DECENTRALIZED_LLM_API_KEY=
LOCAL_FALLBACK_ENABLED=true

GEN_TIMEOUT_MS=30000
GEN_MAX_TOKENS=512
GEN_TEMPERATURE=0.4

DATABASE_URL=file:./data/memphis-v5.db

# Rust/NAPI bridge runtime toggles
RUST_CHAIN_ENABLED=true
# RUST_CHAIN_REQUIRE_SIGNATURES=false
# RUST_CHAIN_SIGNER_KEY_HEX=          # 32-byte hex Ed25519 signing key
RUST_CHAIN_BRIDGE_PATH=./crates/memphis-napi

# Default local embeddings path (recommended)
RUST_EMBED_MODE=ollama # local|openai-compatible|provider|ollama|cohere|voyage|jina|mistral|together|nvidia|mixedbread
RUST_EMBED_DIM=32
RUST_EMBED_MAX_TEXT_BYTES=4096
RUST_EMBED_PROVIDER_URL=http://127.0.0.1:11434/api/embeddings
RUST_EMBED_PROVIDER_API_KEY=
RUST_EMBED_PROVIDER_MODEL=nomic-embed-text
RUST_EMBED_PROVIDER_TIMEOUT_MS=8000

# Vault runtime requirements (required when vault endpoints are used)
MEMPHIS_VAULT_PEPPER=
MEMPHIS_VAULT_ENTRIES_PATH=./data/vault-entries.json

# Gateway /exec hardening policy
GATEWAY_EXEC_RESTRICTED_MODE=true
GATEWAY_EXEC_ALLOWLIST=echo,pwd,ls,whoami,date,uptime
GATEWAY_EXEC_BLOCKED_TOKENS=&&,||,;,|,>,<,$(,`

# Runtime alerting policy (nightly smoke)
OLLAMA_SMOKE_ALERT_WEBHOOK=
ALERT_SEVERITY=critical
ALERT_THROTTLE_SECONDS=1800
