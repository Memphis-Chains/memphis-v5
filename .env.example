NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

DEFAULT_PROVIDER=shared-llm
SHARED_LLM_API_BASE=
SHARED_LLM_API_KEY=
DECENTRALIZED_LLM_API_BASE=
DECENTRALIZED_LLM_API_KEY=
LOCAL_FALLBACK_ENABLED=true

GEN_TIMEOUT_MS=30000
GEN_MAX_TOKENS=512
GEN_TEMPERATURE=0.4

DATABASE_URL=file:./data/memphis-v4.db

# Optional local alert webhook for runtime smoke failures
OLLAMA_SMOKE_ALERT_WEBHOOK=
